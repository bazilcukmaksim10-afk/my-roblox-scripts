local oldGui = game.CoreGui:FindFirstChild("CocoTT2_Gui") or game.Players.LocalPlayer:FindFirstChildOfClass("PlayerGui"):FindFirstChild("CocoTT2_Gui")
if oldGui then oldGui:Destroy() end

local Player = game.Players.LocalPlayer
local Character = Player.Character or Player.CharacterAdded:Wait()
local Humanoid = Character:WaitForChild("Humanoid")
local RootPart = Character:WaitForChild("HumanoidRootPart")

local Noclip = false
local Speed = 100

-- Створення платформи (кубика) під гравцем
local Platform = Instance.new("Part")
Platform.Size = Vector3.new(4, 1, 4)
Platform.Anchored = true
Platform.Transparency = 1 -- Зроби 0, якщо хочеш бачити кубик під собою
Platform.CanCollide = false
Platform.Parent = workspace

local function UpdateWalkSpeed()
    if Humanoid then
        Humanoid.WalkSpeed = Speed
    end
end

Player.CharacterAdded:Connect(function(char)
    Character = char
    Humanoid = char:WaitForChild("Humanoid")
    RootPart = char:WaitForChild("HumanoidRootPart")
    UpdateWalkSpeed()
end)

-- Основний цикл: Ноукліп та керування кубиком під ногами
game:GetService("RunService").Stepped:Connect(function()
    if Character and Humanoid and RootPart then
        if Noclip then
            -- Вимикаємо колізію для персонажа
            for _, part in pairs(Character:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.CanCollide = false
                end
            end
            -- Телепортуємо кубик під ноги, щоб не падати
            Platform.CanCollide = true
            Platform.CFrame = RootPart.CFrame * CFrame.new(0, -3.5, 0)
        else
            Platform.CanCollide = false
            Platform.CFrame = CFrame.new(0, 9999, 0) -- Ховаємо кубик далеко
        end
    end
end)

-- Створення інтерфейсу (GUI)
local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "CocoTT2_Gui"
local success, _ = pcall(function() ScreenGui.Parent = game:GetService("CoreGui") end)
if not success then ScreenGui.Parent = Player:FindFirstChildOfClass("PlayerGui") end

local MainFrame = Instance.new("Frame")
MainFrame.Size = UDim2.new(0, 200, 0, 180)
MainFrame.Position = UDim2.new(0.05, 0, 0.3, 0)
MainFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
MainFrame.BorderSizePixel = 0
MainFrame.Active = true
MainFrame.Draggable = true
MainFrame.Parent = ScreenGui

local Title = Instance.new("TextLabel")
Title.Size = UDim2.new(1, 0, 0, 40)
Title.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
Title.Text = "Coco's TT 2"
Title.TextColor3 = Color3.fromRGB(255, 255, 255)
Title.TextSize = 18
Title.Font = Enum.Font.SourceSansBold
Title.Parent = MainFrame

-- Кнопка Noclip
local NoclipBtn = Instance.new("TextButton")
NoclipBtn.Size = UDim2.new(0.9, 0, 0, 40)
NoclipBtn.Position = UDim2.new(0.05, 0, 0.28, 0)
NoclipBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
NoclipBtn.Text = "Noclip + Платформа: OFF"
NoclipBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
NoclipBtn.Font = Enum.Font.SourceSans
NoclipBtn.TextSize = 14
NoclipBtn.Parent = MainFrame

NoclipBtn.MouseButton1Click:Connect(function()
    Noclip = not Noclip
    if Noclip then
        NoclipBtn.Text = "Noclip + Платформа: ON"
        NoclipBtn.BackgroundColor3 = Color3.fromRGB(0, 150, 0)
    else
        NoclipBtn.Text = "Noclip + Платформа: OFF"
        NoclipBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
    end
end)

local SpeedLabel = Instance.new("TextLabel")
SpeedLabel.Size = UDim2.new(0.9, 0, 0, 30)
SpeedLabel.Position = UDim2.new(0.05, 0, 0.52, 0)
SpeedLabel.BackgroundTransparency = 1
SpeedLabel.Text = "Швидкість бігу: " .. Speed
SpeedLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
SpeedLabel.TextSize = 14
SpeedLabel.Font = Enum.Font.SourceSans
SpeedLabel.Parent = MainFrame

local SpeedUp = Instance.new("TextButton")
SpeedUp.Size = UDim2.new(0.42, 0, 0, 30)
SpeedUp.Position = UDim2.new(0.53, 0, 0.72, 0)
SpeedUp.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
SpeedUp.Text = "+50"
SpeedUp.TextColor3 = Color3.fromRGB(255, 255, 255)
SpeedUp.Parent = MainFrame

SpeedUp.MouseButton1Click:Connect(function()
    Speed = math.min(Speed + 50, 500)
    SpeedLabel.Text = "Швидкість бігу: " .. Speed
    UpdateWalkSpeed()
end)

local SpeedDown = Instance.new("TextButton")
SpeedDown.Size = UDim2.new(0.42, 0, 0, 30)
SpeedDown.Position = UDim2.new(0.05, 0, 0.72, 0)
SpeedDown.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
SpeedDown.Text = "-50"
SpeedDown.TextColor3 = Color3.fromRGB(255, 255, 255)
SpeedDown.Parent = MainFrame

SpeedDown.MouseButton1Click:Connect(function()
    Speed = math.max(Speed - 50, 16)
    SpeedLabel.Text = "Швидкість бігу: " .. Speed
    UpdateWalkSpeed()
end)

UpdateWalkSpeed()
