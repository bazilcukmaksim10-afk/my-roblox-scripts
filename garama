local oldGui = game.CoreGui:FindFirstChild("CocoTT2_Gui") or game.Players.LocalPlayer:FindFirstChildOfClass("PlayerGui"):FindFirstChild("CocoTT2_Gui")
if oldGui then oldGui:Destroy() end

local Player = game.Players.LocalPlayer
local Character = Player.Character or Player.CharacterAdded:Wait()
local Humanoid = Character:WaitForChild("Humanoid")
local RootPart = Character:WaitForChild("HumanoidRootPart")

local SpinActive = false
local Speed = 150

-- Створення платформи під гравцем
local Platform = Instance.new("Part")
Platform.Size = Vector3.new(4, 1, 4)
Platform.Anchored = true
Platform.Transparency = 1
Platform.CanCollide = false
Platform.Parent = workspace

-- Керування крутилкою
local Spin = Instance.new("BodyAngularVelocity")
Spin.MaxTorque = Vector3.new(0, math.huge, 0)
Spin.AngularVelocity = Vector3.new(0, 10000000, 0) -- Гіпер-швидкість крутіння

-- Функція перетворення на МАЛЕНЬКИЙ квадрат
local function MakeSmallCube()
    if Character then
        for _, part in pairs(Character:GetDescendants()) do
            if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
                part.Transparency = 1
            elseif part:IsA("CharacterMesh") or part:IsA("Shirt") or part:IsA("Pants") or part:IsA("Accessory") then
                part:Destroy()
            end
        end
        
        if not RootPart:FindFirstChild("VisualCube") then
            local Cube = Instance.new("Part")
            Cube.Name = "VisualCube"
            Cube.Size = Vector3.new(1.2, 1.2, 1.2) -- Маленький розмір кубика
            Cube.Color = Color3.fromRGB(85, 255, 85) -- Яскравий зелений колір
            Cube.CanCollide = false
            Cube.Parent = RootPart
            
            local Weld = Instance.new("Weld")
            Weld.Part0 = RootPart
            Weld.Part1 = Cube
            Weld.C0 = CFrame.new(0, 0, 0)
            Weld.Parent = Cube
        end
    end
end

local function UpdateWalkSpeed()
    if Humanoid then Humanoid.WalkSpeed = Speed end
end

Player.CharacterAdded:Connect(function(char)
    Character = char
    Humanoid = char:WaitForChild("Humanoid")
    RootPart = char:WaitForChild("HumanoidRootPart")
    task.wait(0.5)
    MakeSmallCube()
    UpdateWalkSpeed()
end)

-- Основний цикл: Ноукліп, Платформа та Обертання
game:GetService("RunService").Stepped:Connect(function()
    if Character and Humanoid and RootPart then
        if SpinActive then
            for _, part in pairs(Character:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.CanCollide = false
                end
            end
            Platform.CanCollide = true
            Platform.CFrame = RootPart.CFrame * CFrame.new(0, -2.1, 0)
            Spin.Parent = RootPart -- Вмикаємо крутилку
        else
            Platform.CanCollide = false
            Platform.CFrame = CFrame.new(0, 9999, 0)
            Spin.Parent = nil -- Вимикаємо крутилку
        end
    end
end)

