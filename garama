local oldGui = game.CoreGui:FindFirstChild("CocoTT2_Gui") or game.Players.LocalPlayer:FindFirstChildOfClass("PlayerGui"):FindFirstChild("CocoTT2_Gui")
if oldGui then oldGui:Destroy() end

local Player = game.Players.LocalPlayer
local Character = Player.Character or Player.CharacterAdded:Wait()
local Humanoid = Character:WaitForChild("Humanoid")
local RootPart = Character:WaitForChild("HumanoidRootPart")

local Flying = false
local Noclip = false
local Speed = 100

local BodyVelocity = Instance.new("BodyVelocity")
local BodyGyro = Instance.new("BodyGyro")
BodyVelocity.MaxForce = Vector3.new(1, 1, 1) * math.huge
BodyGyro.MaxTorque = Vector3.new(1, 1, 1) * math.huge

-- Оновлення швидкості бігу
local function UpdateWalkSpeed()
    if Humanoid and not Flying then
        Humanoid.WalkSpeed = Speed
    elseif Humanoid and Flying then
        Humanoid.WalkSpeed = 16 -- стандартна швидкість, коли літає
    end
end

Player.CharacterAdded:Connect(function(char)
    Character = char
    Humanoid = char:WaitForChild("Humanoid")
    RootPart = char:WaitForChild("HumanoidRootPart")
    UpdateWalkSpeed()
end)

game:GetService("RunService").Stepped:Connect(function()
    if Noclip and Character then
        for _, part in pairs(Character:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = false
            end
        end
    end
end)

task.spawn(function()
    while true do
        if Flying and RootPart and Humanoid then
            local Camera = workspace.CurrentCamera
            BodyVelocity.Velocity = Humanoid.MoveDirection * Speed
            BodyGyro.CFrame = Camera.CFrame
        end
        task.wait()
    end
end)

local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "CocoTT2_Gui"
local success, _ = pcall(function() ScreenGui.Parent = game:GetService("CoreGui") end)
if not success then ScreenGui.Parent = Player:FindFirstChildOfClass("PlayerGui") end

local MainFrame = Instance.new("Frame")
MainFrame.Size = UDim2.new(0, 200, 0, 220)
MainFrame.Position = UDim2.new(0.05, 0, 0.3, 0)
MainFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
MainFrame.BorderSizePixel = 0
MainFrame.Active = true
MainFrame.Draggable = true
MainFrame.Parent = ScreenGui

local Title = Instance.new("TextLabel")
Title.Size = UDim2.new(1, 0, 0, 40)
Title.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
Title.Text = "Coco's TT 2"
Title.TextColor3 = Color3.fromRGB(255, 255, 255)
Title.TextSize = 18
Title.Font = Enum.Font.SourceSansBold
Title.Parent = MainFrame

local FlyBtn = Instance.new("TextButton")
FlyBtn.Size = UDim2.new(0.9, 0, 0, 40)
FlyBtn.Position = UDim2.new(0.05, 0, 0.25, 0)
FlyBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
FlyBtn.Text = "Fly: OFF"
FlyBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
FlyBtn.Font = Enum.Font.SourceSans
FlyBtn.TextSize = 16
FlyBtn.Parent = MainFrame

FlyBtn.MouseButton1Click:Connect(function()
    Flying = not Flying
    if Flying then
        FlyBtn.Text = "Fly: ON"
        FlyBtn.BackgroundColor3 = Color3.fromRGB(0, 150, 0)
        BodyVelocity.Parent = RootPart
        BodyGyro.Parent = RootPart
        Humanoid.PlatformStand = true
    else
        FlyBtn.Text = "Fly: OFF"
        FlyBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
        BodyVelocity.Parent = nil
        BodyGyro.Parent = nil
        Humanoid.PlatformStand = false
    end
    UpdateWalkSpeed()
end)

local NoclipBtn = Instance.new("TextButton")
NoclipBtn.Size = UDim2.new(0.9, 0, 0, 40)
NoclipBtn.Position = UDim2.new(0.05, 0, 0.48, 0)
NoclipBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
NoclipBtn.Text = "Noclip: OFF"
NoclipBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
NoclipBtn.Font = Enum.Font.SourceSans
NoclipBtn.TextSize = 16
NoclipBtn.Parent = MainFrame

NoclipBtn.MouseButton1Click:Connect(function()
    Noclip = not Noclip
    if Noclip then
        NoclipBtn.Text = "Noclip: ON"
        NoclipBtn.BackgroundColor3 = Color3.fromRGB(0, 150, 0)
    else
        NoclipBtn.Text = "Noclip: OFF"
        NoclipBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
    end
end)

local SpeedLabel = Instance.new("TextLabel")
SpeedLabel.Size = UDim2.new(0.9, 0, 0, 30)
SpeedLabel.Position = UDim2.new(0.05, 0, 0.7, 0)
SpeedLabel.BackgroundTransparency = 1
SpeedLabel.Text = "Швидкість: " .. Speed
SpeedLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
SpeedLabel.TextSize = 14
SpeedLabel.Font = Enum.Font.SourceSans
SpeedLabel.Parent = MainFrame

local SpeedUp = Instance.new("TextButton")
SpeedUp.Size = UDim2.new(0.42, 0, 0, 30)
SpeedUp.Position = UDim2.new(0.53, 0, 0.83, 0)
SpeedUp.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
SpeedUp.Text = "+50"
SpeedUp.TextColor3 = Color3.fromRGB(255, 255, 255)
SpeedUp.Parent = MainFrame

SpeedUp.MouseButton1Click:Connect(function()
    Speed = math.min(Speed + 50, 500)
    SpeedLabel.Text = "Швидкість: " .. Speed
    UpdateWalkSpeed()
end)

local SpeedDown = Instance.new("TextButton")
SpeedDown.Size = UDim2.new(0.42, 0, 0, 30)
SpeedDown.Position = UDim2.new(0.05, 0, 0.83, 0)
SpeedDown.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
SpeedDown.Text = "-50"
SpeedDown.TextColor3 = Color3.fromRGB(255, 255, 255)
SpeedDown.Parent = MainFrame

SpeedDown.MouseButton1Click:Connect(function()
    Speed = math.max(Speed - 50, 16)
    SpeedLabel.Text = "Швидкість: " .. Speed
    UpdateWalkSpeed()
end)

UpdateWalkSpeed()
