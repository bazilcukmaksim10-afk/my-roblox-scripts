    if SpinActive then
        SpinBtn.Text = "Гіпер-Крутилка: ON"
        SpinBtn.BackgroundColor3 = Color3.fromRGB(0, 150, 0)
    else
        SpinBtn.Text = "Гіпер-Крутилка: OFF"
        SpinBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
    end
end)

MakeSmallCube()
UpdateWalkSpeed()
