local oldGui = game.CoreGui:FindChildUnique("CocoMM2_MegaGui") or game.Players.LocalPlayer:FindFirstChildOfClass("PlayerGui"):FindFirstChildUnique("CocoMM2_MegaGui")
if oldGui then oldGui:Destroy() end

local Player = game.Players.LocalPlayer
local Character = Player.Character or Player.CharacterAdded:Wait()
local Humanoid = Character:WaitForChild("Humanoid")
local RootPart = Character:WaitForChild("HumanoidRootPart")

-- Функція для визначення ролі гравця в Murder Mystery 2
local function GetPlayerRole(p)
    if p.Backpack:FindFirstChild("Knife") or (p.Character and p.Character:FindFirstChild("Knife")) then
        return "Murder"
    elseif p.Backpack:FindFirstChild("Gun") or (p.Character and p.Character:FindFirstChild("Gun")) then
        return "Sheriff"
    end
    return "Innocent"
end

-- Створення ESP (Нікнейм + Роль із кольором)
local function CreateESP(p)
    if p == Player then return end
    
    local function ApplyESP(char)
        local head = char:WaitForChild("Head", 5)
        if not head then return end
        
        -- Видаляємо старий ESP, якщо він є
        if head:FindFirstChild("ESP_Billboard") then head.ESP_Billboard:Destroy() end
        
        local billboard = Instance.new("BillboardGui")
        billboard.Name = "ESP_Billboard"
        billboard.AlwaysOnTop = true
        billboard.Size = UDim2.new(0, 200, 0, 50)
        billboard.StudsOffset = Vector3.new(0, 2, 0)
        billboard.Parent = head
        
        local textLabel = Instance.new("TextLabel")
        textLabel.Size = UDim2.new(1, 0, 1, 0)
        textLabel.BackgroundTransparency = 1
        textLabel.TextSize = 14
        textLabel.Font = Enum.Font.SourceSansBold
        textLabel.TextStrokeTransparency = 0
        textLabel.Parent = billboard
        
        -- Оновлення тексту та кольору залежно від ролі
        local connection
        connection = game:GetService("RunService").RenderStepped:Connect(function()
            if not char:IsDescendantOf(workspace) or not p:IsDescendantOf(game.Players) then
                connection:Disconnect()
                return
            end
            
            local role = GetPlayerRole(p)
            textLabel.Text = p.Name .. " [" .. role .. "]"
            
            if role == "Murder" then
                textLabel.TextColor3 = Color3.fromRGB(255, 0, 0) -- Червоний
            elseif role == "Sheriff" then
                textLabel.TextColor3 = Color3.fromRGB(0, 0, 255) -- Синій
            else
                textLabel.TextColor3 = Color3.fromRGB(0, 255, 0) -- Зелений
            end
        end)
    end
    
    if p.Character then ApplyESP(p.Character) end
    p.CharacterAdded:Connect(ApplyESP)
end

-- Запуск ESP для всіх гравців
for _, p in pairs(game.Players:GetPlayers()) do CreateESP(p) end
game.Players.PlayerAdded:Connect(CreateESP)

-- ФУНКЦІЇ ТЕЛЕПОРТУ

-- Телепорт до Мардера
local function TeleportToMurder()
    for _, p in pairs(game.Players:GetPlayers()) do
        if GetPlayerRole(p) == "Murder" and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            RootPart.CFrame = p.Character.HumanoidRootPart.CFrame * CFrame.new(0, 0, 3)
            return
        end
    end
end

-- Телепорт до Шерифа
local function TeleportToSheriff()
    for _, p in pairs(game.Players:GetPlayers()) do
        if GetPlayerRole(p) == "Sheriff" and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            RootPart.CFrame = p.Character.HumanoidRootPart.CFrame * CFrame.new(0, 0, 3)
            return
        end
    end
end

-- Приклад активації через клавіші (можна прибрати або змінити):
-- Натисніть "T", щоб тп до Мардера, натисніть "Y", щоб тп до Шерифа
game:GetService("UserInputService").InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == Enum.KeyCode.T then
        TeleportToMurder()
    elseif input.KeyCode == Enum.KeyCode.Y then
        TeleportToSheriff()
    end
end)
